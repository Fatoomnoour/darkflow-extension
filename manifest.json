{
  "manifest_version": 3,
  "name": "DarkFlow - الوضع الداكن",
  "version": "1.0.0",
  "description": "تفعيل الوضع الداكن على أي موقع بذكاء مع تحكم كامل بالشدة",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "DarkFlow"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["dark.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}